{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Rankwell",
  "version": "0.2.0",
  "identifier": "com.rankwell.app",
  "build": {
    "frontendDist": "../web-dist",
    "devUrl": "http://127.0.0.1:5279",
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build:server"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rankwell",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "fullscreen": false,
        "url": "http://127.0.0.1:5279"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/server"],
    "resources": {
      "server-dist/": "server-dist/"
    }
  }
}
